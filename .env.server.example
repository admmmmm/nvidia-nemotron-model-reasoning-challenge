# Copy this file to .env.server on the server and fill in the values you need.
# The training scripts will source it automatically.

# Hugging Face
HF_TOKEN=
HF_HOME=${HOME}/.cache/huggingface

# Conda / environment
ENV_NAME=nemotron
PYTHON_VERSION=3.10
PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cu121

# Training job naming
RUN_NAME=nemotron_lora_v0

# Model + data
MODEL_NAME=nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-BF16
TRAIN_FILE=train.csv
TEST_FILE=test.csv
SPLIT_DIR=data/splits/default
OUTPUT_DIR=outputs/adapters/nemotron_lora_v0
LOG_DIR=outputs/logs

# Training hyperparameters
MAX_LENGTH=2048
NUM_EPOCHS=1
LEARNING_RATE=1e-4
PER_DEVICE_TRAIN_BATCH_SIZE=1
PER_DEVICE_EVAL_BATCH_SIZE=1
GRADIENT_ACCUMULATION_STEPS=16
LOGGING_STEPS=10
SAVE_STEPS=100
EVAL_STEPS=100
LORA_RANK=16
LORA_ALPHA=32
LORA_DROPOUT=0.05

# Optional fast smoke/debug mode
TRAIN_LIMIT=
VAL_LIMIT=
MAX_STEPS=-1
MAX_MEMORY_GPU=39GiB
MAX_MEMORY_CPU=32GiB
LOCAL_FILES_ONLY=1
FORCE_FULL_GPU=0

# Git auto-push after the run
AUTO_GIT_PUSH=0
GIT_BRANCH=master
GIT_COMMIT_MESSAGE=

# Optional lightweight notifications
# Example for Server?: https://sctapi.ftqq.com/<SENDKEY>.send
WEBHOOK_URL=
# Example for Bark: https://api.day.app/<device_key>
BARK_URL=

# Auto-stop / auto-shutdown
AUTO_SHUTDOWN=0
# If your platform provides a stop-instance command or API call, put it here.
STOP_COMMAND=
